# ==========================================
# Angular & Node.js Production .gitignore
# ==========================================

# --- Dependencies & Package Managers ---
node_modules/
/jspm_packages/
.npm/
.eslintcache/

# --- Angular Build & Cache Outputs ---
.angular/
/dist/
/.next/
/out/
.keystone/

# --- IDEs and Editors ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Environment Secrets & Configs ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key

# --- Testing & Code Coverage ---
/coverage/
.nyc_output/
*.lcov
.c8_output/

# --- Logs & Diagnostics ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS / System Clutter ---
.DS_Store
.DS_Store?
._*
Thumbstacks.db
ehthumbs.db
Icon?
Thumbs.db